<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1/events"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

  <owl:Ontology rdf:about="http://example.org/f1/events">
    <rdfs:label>F1 Events</rdfs:label>
    <owl:imports rdf:resource="http://example.org/f1/core"/>
  </owl:Ontology>

  <owl:Class rdf:about="http://example.org/f1#Season">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#EventThing"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#GrandPrix">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#EventThing"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#Circuit">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Location"/>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/f1#Session">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#EventThing"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#PracticeSession">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Session"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#QualifyingSession">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Session"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#SprintSession">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Session"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#RaceSession">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Session"/>
  </owl:Class>

  <owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
      <rdf:Description rdf:about="http://example.org/f1#PracticeSession"/>
      <rdf:Description rdf:about="http://example.org/f1#QualifyingSession"/>
      <rdf:Description rdf:about="http://example.org/f1#SprintSession"/>
      <rdf:Description rdf:about="http://example.org/f1#RaceSession"/>
    </owl:members>
  </owl:AllDisjointClasses>

  <!-- Event properties -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#partOfSeason">
    <rdfs:domain rdf:resource="http://example.org/f1#EventThing"/>
    <rdfs:range  rdf:resource="http://example.org/f1#Season"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/f1#hasGrandPrix">
    <rdfs:domain rdf:resource="http://example.org/f1#Season"/>
    <rdfs:range  rdf:resource="http://example.org/f1#GrandPrix"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/f1#hostsAtCircuit">
    <rdfs:domain rdf:resource="http://example.org/f1#GrandPrix"/>
    <rdfs:range  rdf:resource="http://example.org/f1#Circuit"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/f1#hasSession">
    <rdfs:domain rdf:resource="http://example.org/f1#GrandPrix"/>
    <rdfs:range  rdf:resource="http://example.org/f1#Session"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/f1#sessionOfEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range  rdf:resource="http://example.org/f1#GrandPrix"/>
  </owl:ObjectProperty>

  <!-- Minimal weather/flag enums -->
  <owl:Class rdf:about="http://example.org/f1#WeatherCondition">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Quality"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#DryWeather"><rdfs:subClassOf rdf:resource="http://example.org/f1#WeatherCondition"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#WetWeather"><rdfs:subClassOf rdf:resource="http://example.org/f1#WeatherCondition"/></owl:Class>

  <owl:Class rdf:about="http://example.org/f1#FlagStatus">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Quality"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#GreenFlag"><rdfs:subClassOf rdf:resource="http://example.org/f1#FlagStatus"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#RedFlag"><rdfs:subClassOf rdf:resource="http://example.org/f1#FlagStatus"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#YellowFlag"><rdfs:subClassOf rdf:resource="http://example.org/f1#FlagStatus"/></owl:Class>

  <owl:ObjectProperty rdf:about="http://example.org/f1#hasWeather">
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range  rdf:resource="http://example.org/f1#WeatherCondition"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasFlagStatus">
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range  rdf:resource="http://example.org/f1#FlagStatus"/>
  </owl:ObjectProperty>

</rdf:RDF>
