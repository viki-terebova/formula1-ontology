<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://example.org/f1">
    <owl:imports rdf:resource="http://example.org/f1/core"/>
    <owl:imports rdf:resource="http://example.org/f1/events"/>
    <owl:imports rdf:resource="http://example.org/f1/teams"/>
    <owl:imports rdf:resource="http://example.org/f1/vehicle"/>
    <owl:imports rdf:resource="http://example.org/f1/competition"/>
    <owl:imports rdf:resource="http://example.org/f1/individuals"/>
  </owl:Ontology>

</rdf:RDF>
