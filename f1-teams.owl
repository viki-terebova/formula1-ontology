<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1/teams"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

  <owl:Ontology rdf:about="http://example.org/f1/teams">
    <rdfs:label>F1 Teams & Entries</rdfs:label>
    <owl:imports rdf:resource="http://example.org/f1/core"/>
    <owl:imports rdf:resource="http://example.org/f1/events"/>
    <owl:imports rdf:resource="http://example.org/f1/properties"/>
  </owl:Ontology>

  <owl:Class rdf:about="http://example.org/f1#TeamEntry">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#EventThing"/>
  </owl:Class>
</rdf:RDF>
