<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1/individuals"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://example.org/f1/individuals">
    <owl:imports rdf:resource="http://example.org/f1/core"/>
    <owl:imports rdf:resource="http://example.org/f1/events"/>
    <owl:imports rdf:resource="http://example.org/f1/teams"/>
  </owl:Ontology>

  <!-- Season -->
  <owl:NamedIndividual rdf:about="http://example.org/f1#Season2024">
    <rdf:type rdf:resource="http://example.org/f1#Season"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#Season2025">
    <rdf:type rdf:resource="http://example.org/f1#Season"/>
  </owl:NamedIndividual>

  <!-- Teams -->
  <owl:NamedIndividual rdf:about="http://example.org/f1#MercedesAMGPetronas">
    <rdf:type rdf:resource="http://example.org/f1#Team"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#OracleRedBullRacing">
    <rdf:type rdf:resource="http://example.org/f1#Team"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#ScuderiaFerrari">
    <rdf:type rdf:resource="http://example.org/f1#Team"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#McLarenF1Team">
    <rdf:type rdf:resource="http://example.org/f1#Team"/>
  </owl:NamedIndividual>

  <!-- Team entries -->
  <owl:NamedIndividual rdf:about="http://example.org/f1#MercedesEntry2024">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#MercedesAMGPetronas"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2024"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#LewisHamilton"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#GeorgeRussell"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#RedBullEntry2024">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#OracleRedBullRacing"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2024"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#MaxVerstappen"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#SergioPerez"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#FerrariEntry2024">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#ScuderiaFerrari"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2024"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#CharlesLeclerc"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#CarlosSainz"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#McLarenEntry2024">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#McLarenF1Team"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2024"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#LandoNorris"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#OscarPiastri"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#MercedesEntry2025">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#MercedesAMGPetronas"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2025"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#GeorgeRussell"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#RedBullEntry2025">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#OracleRedBullRacing"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2025"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#MaxVerstappen"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#SergioPerez"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#FerrariEntry2025">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#ScuderiaFerrari"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2025"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#CharlesLeclerc"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#LewisHamilton"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#McLarenEntry2025">
    <rdf:type rdf:resource="http://example.org/f1#TeamEntry"/>
    <f1:enteredBy rdf:resource="http://example.org/f1#McLarenF1Team"/>
    <f1:entryInSeason rdf:resource="http://example.org/f1#Season2025"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#LandoNorris"/>
    <f1:hasDriver rdf:resource="http://example.org/f1#OscarPiastri"/>
  </owl:NamedIndividual>

  <!-- Drivers -->
  <owl:NamedIndividual rdf:about="http://example.org/f1#LewisHamilton">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#MercedesEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#FerrariEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#GeorgeRussell">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#MercedesEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#MercedesEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#MaxVerstappen">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#RedBullEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#RedBullEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#SergioPerez">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#RedBullEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#RedBullEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#CharlesLeclerc">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#FerrariEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#FerrariEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#CarlosSainz">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#FerrariEntry2024"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#LandoNorris">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#McLarenEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#McLarenEntry2025"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://example.org/f1#OscarPiastri">
    <rdf:type rdf:resource="http://example.org/f1#Driver"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#McLarenEntry2024"/>
    <f1:drivesForEntry rdf:resource="http://example.org/f1#McLarenEntry2025"/>
  </owl:NamedIndividual>

</rdf:RDF>
