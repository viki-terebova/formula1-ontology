<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1/properties"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://example.org/f1/properties">
    <owl:imports rdf:resource="http://example.org/f1/core"/>
    <owl:imports rdf:resource="http://example.org/f1/events"/>
    <owl:imports rdf:resource="http://example.org/f1/teams"/>
    <owl:imports rdf:resource="http://example.org/f1/vehicle"/>
    <owl:imports rdf:resource="http://example.org/f1/competition"/>
  </owl:Ontology>

  <!-- Location -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#locatedInCountry">
    <rdfs:domain rdf:resource="http://example.org/f1#Location"/>
    <rdfs:range rdf:resource="http://example.org/f1#Country"/>
  </owl:ObjectProperty>

  <!-- Events -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#partOfSeason">
    <rdfs:domain rdf:resource="http://example.org/f1#EventThing"/>
    <rdfs:range rdf:resource="http://example.org/f1#Season"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasGrandPrix">
    <rdfs:domain rdf:resource="http://example.org/f1#Season"/>
    <rdfs:range rdf:resource="http://example.org/f1#GrandPrix"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hostsAtCircuit">
    <rdfs:domain rdf:resource="http://example.org/f1#GrandPrix"/>
    <rdfs:range rdf:resource="http://example.org/f1#Circuit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasSession">
    <rdfs:domain rdf:resource="http://example.org/f1#GrandPrix"/>
    <rdfs:range rdf:resource="http://example.org/f1#Session"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#sessionOfEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range rdf:resource="http://example.org/f1#GrandPrix"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasWeather">
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range rdf:resource="http://example.org/f1#WeatherCondition"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasFlagStatus">
    <rdfs:domain rdf:resource="http://example.org/f1#Session"/>
    <rdfs:range rdf:resource="http://example.org/f1#FlagStatus"/>
  </owl:ObjectProperty>

  <!-- Competition / participation -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#participationOfDriver">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#Driver"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#participationForEntry">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#TeamEntry"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#participationInSession">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#Session"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#usedTyreSet">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#TyreSet"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasFinishStatus">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#FinishStatus"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#incursPenalty">
    <rdfs:domain rdf:resource="http://example.org/f1#Participation"/>
    <rdfs:range rdf:resource="http://example.org/f1#Penalty"/>
  </owl:ObjectProperty>

  <!-- Teams / entries -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#enteredBy">
    <rdfs:domain rdf:resource="http://example.org/f1#TeamEntry"/>
    <rdfs:range rdf:resource="http://example.org/f1#Team"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#entryInSeason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/f1#TeamEntry"/>
    <rdfs:range rdf:resource="http://example.org/f1#Season"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasDriver">
    <rdfs:domain rdf:resource="http://example.org/f1#TeamEntry"/>
    <rdfs:range rdf:resource="http://example.org/f1#Driver"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#drivesForEntry">
    <rdfs:domain rdf:resource="http://example.org/f1#Driver"/>
    <rdfs:range rdf:resource="http://example.org/f1#TeamEntry"/>
  </owl:ObjectProperty>

  <!-- Vehicle -->
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasChassis">
    <rdfs:domain rdf:resource="http://example.org/f1#Car"/>
    <rdfs:range rdf:resource="http://example.org/f1#Chassis"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasPowerUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/f1#Car"/>
    <rdfs:range rdf:resource="http://example.org/f1#PowerUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#hasGearbox">
    <rdfs:domain rdf:resource="http://example.org/f1#Car"/>
    <rdfs:range rdf:resource="http://example.org/f1#Gearbox"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/f1#usesTyreCompound">
    <rdfs:domain rdf:resource="http://example.org/f1#TyreSet"/>
    <rdfs:range rdf:resource="http://example.org/f1#TyreCompound"/>
  </owl:ObjectProperty>

</rdf:RDF>
