<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/f1#"
         xml:base="http://example.org/f1/vehicle"
         xmlns:f1="http://example.org/f1#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

  <owl:Ontology rdf:about="http://example.org/f1/vehicle">
    <rdfs:label>F1 Vehicle</rdfs:label>
    <owl:imports rdf:resource="http://example.org/f1/core"/>
    <owl:imports rdf:resource="http://example.org/f1/properties"/>
  </owl:Ontology>

  <owl:Class rdf:about="http://example.org/f1#Car">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#CompetitionAsset"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#Chassis">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#CompetitionAsset"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#PowerUnit">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#CompetitionAsset"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#Gearbox">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#CompetitionAsset"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#TyreSet">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#CompetitionAsset"/>
  </owl:Class>

  <!-- Tyre compounds (value partition lite) -->
  <owl:Class rdf:about="http://example.org/f1#TyreCompound">
    <rdfs:subClassOf rdf:resource="http://example.org/f1#Characteristics"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/f1#SoftCompound"><rdfs:subClassOf rdf:resource="http://example.org/f1#TyreCompound"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#MediumCompound"><rdfs:subClassOf rdf:resource="http://example.org/f1#TyreCompound"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#HardCompound"><rdfs:subClassOf rdf:resource="http://example.org/f1#TyreCompound"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#IntermediateCompound"><rdfs:subClassOf rdf:resource="http://example.org/f1#TyreCompound"/></owl:Class>
  <owl:Class rdf:about="http://example.org/f1#WetCompound"><rdfs:subClassOf rdf:resource="http://example.org/f1#TyreCompound"/></owl:Class>
  <owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
      <rdf:Description rdf:about="http://example.org/f1#SoftCompound"/>
      <rdf:Description rdf:about="http://example.org/f1#MediumCompound"/>
      <rdf:Description rdf:about="http://example.org/f1#HardCompound"/>
      <rdf:Description rdf:about="http://example.org/f1#IntermediateCompound"/>
      <rdf:Description rdf:about="http://example.org/f1#WetCompound"/>
    </owl:members>
  </owl:AllDisjointClasses>

</rdf:RDF>
